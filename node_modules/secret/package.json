{
  "name": "secret",
  "version": "2.0.1",
  "private": false,
  "main": "dist/index.js",
  "license": "MIT",
  "prettier": "@unix/prettier",
  "files": [
    "dist",
    "README.md",
    "package.json",
    "tsconfig.json",
    "self-host.ts"
  ],
  "func": {
    "entry": "src/index.ts",
    "outDir": "dist"
  },
  "bin": {
    "cli": "./dist/bin.js"
  },
  "dependencies": {
    "func": "^2.1.0",
    "secret-cipher": "^0.1.1",
    "yocto-spinner": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@unix/prettier": "^0.1.0",
    "funcgo": "^0.1.3",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "scripts": {
    "dev": "funcgo dev --",
    "build": "pnpm --filter secret-cipher build && funcgo build",
    "setup": "funcgo setup",
    "test": "pnpm build && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "pnpm build && pnpm publish --access public --no-git-checks"
  }
}